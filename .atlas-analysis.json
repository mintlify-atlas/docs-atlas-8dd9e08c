  "keyFeatures": [
    "Multi-agent system for autonomous scientific research",
    "Deep research mode with iterative hypothesis-driven investigation",
    "Configurable literature search backends (OpenScholar, Edison, BioLit)",
    "Data analysis agents with file upload support",
    "Unified LLM provider interface (OpenAI, Anthropic, Google, OpenRouter)",
    "Vector database with semantic search and reranking",
    "JWT and micropayment authentication (x402/b402)",
    "BullMQ job queue for horizontal scaling",
    "LaTeX paper generation from research conversations",
    "Real-time WebSocket notifications"
  ],
  "publicApiSurface": [
    "POST /api/chat - Agent-based chat with literature search",
    "POST /api/deep-research/start - Start deep research job",
    "GET /api/deep-research/status/:messageId - Check research status",
    "POST /api/deep-research/conversations/:conversationId/paper - Generate research paper",
    "POST /api/files/upload - Direct file upload to S3",
    "GET /api/artifacts/download - Download generated artifacts",
    "POST /api/x402/chat - Payment-gated chat (Base/USDC)",
    "POST /api/b402/chat - Payment-gated chat (BNB/USDT)",
    "GET /admin/queues - Bull Board dashboard",
    "fileUploadAgent() - Parse and store uploaded files",
    "planningAgent() - Generate research plans",
    "literatureAgent() - Search scientific literature",
    "analysisAgent() - Perform data analysis",
    "hypothesisAgent() - Generate research hypotheses",
    "reflectionAgent() - Extract insights and update methodology",
    "discoveryAgent() - Identify novel claims",
    "replyAgent() - Generate user-facing responses",
    "LLM class - Unified provider interface for chat completions"
  ]
}
